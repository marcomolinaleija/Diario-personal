<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="color-scheme" content="light dark">
  <title><%= locals.title %> - <%= locals.appName %></title>
  <link rel="stylesheet" href="/public/css/styles.css">
</head>
<body>
  <a class="skip-link" href="#contenido">Saltar al contenido principal</a>
  <header class="site-header">
    <div class="site-header__inner">
      <a class="brand" href="/" aria-label="<%= locals.appName %>, inicio"><%= locals.appName %></a>
      <nav class="site-nav" aria-label="Navegación principal">
        <a href="/" <% if (locals.currentPath === '/') { %>aria-current="page"<% } %>>Entradas</a>
        <a href="/calendar" <% if (locals.currentPath.startsWith('/calendar')) { %>aria-current="page"<% } %>>Calendario</a>
        <a href="/milestones" <% if (locals.currentPath.startsWith('/milestones')) { %>aria-current="page"<% } %>>Hitos</a>
        <a href="/stats" <% if (locals.currentPath.startsWith('/stats')) { %>aria-current="page"<% } %>>Estadísticas</a>
        <a class="button button--primary" href="/entries/new">Nueva entrada</a>
      </nav>
    </div>
  </header>
  <main id="contenido" class="page" tabindex="-1">
