NODE_ENV=production
HOST=0.0.0.0
PORT=3000
PUBLISHED_HOST=127.0.0.1
IMAGE_TAG=latest
DATABASE_PATH=/app/data/diario.sqlite
ATTACHMENTS_DIR=/app/data/attachments
COOKIE_SECRET=replace-with-a-long-random-secret
